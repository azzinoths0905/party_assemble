.address-picker-page {
  min-height: 100vh;
  background: #ffffff;
}

.address-picker-page__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 32rpx 24rpx;
}

.address-picker-page__action {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.address-picker-page__action--primary {
  color: #111827;
}

.address-picker-page__search {
  padding: 0 24rpx 24rpx;
}

.address-picker-page__input {
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
  background: #f3f4f6;
  font-size: 28rpx;
}

.address-picker-page__map-wrap {
  position: relative;
}

.address-picker-page__map {
  width: 100%;
  height: 620rpx;
}

.address-picker-page__pin {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 52rpx;
  height: 52rpx;
  transform: translate(-50%, -72%);
  border-radius: 50% 50% 50% 0;
  background: #ff5f6d;
  box-shadow: 0 18rpx 40rpx rgba(255, 95, 109, 0.28);
}

.address-picker-page__pin::after {
  content: "";
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #ffffff;
}

.address-picker-page__results {
  padding: 12rpx 0 36rpx;
  background: #ffffff;
}

.address-picker-page__result {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.address-picker-page__result--active {
  background: rgba(22, 196, 127, 0.08);
}

.address-picker-page__result-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.address-picker-page__result-detail {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.address-picker-page__empty {
  padding: 48rpx 32rpx;
  text-align: center;
  color: #6b7280;
  font-size: 28rpx;
}
