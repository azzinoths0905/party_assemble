page {
  min-height: 100%;
  background: #f5f7fb;
  color: #1f2937;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
  box-sizing: border-box;
}

.status-bar-spacer {
  width: 100%;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0 24rpx;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 42rpx;
  font-weight: 700;
  color: #111827;
}

.header-side {
  min-width: 120rpx;
  display: flex;
  align-items: center;
}

.header-side--right {
  justify-content: flex-end;
}

.nav-pill,
.icon-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
  color: #243b53;
  font-size: 26rpx;
  font-weight: 600;
}

.icon-pill {
  min-width: 72rpx;
  padding: 0 24rpx;
}

.section-title {
  font-size: 60rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #111827;
}

.section-subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #6b7280;
}

.card {
  background: #ffffff;
  border-radius: 36rpx;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.08);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #16c47f 0%, #0ea870 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 28rpx;
  background: rgba(22, 196, 127, 0.12);
  color: #0f9f68;
  font-size: 30rpx;
  font-weight: 700;
}

.text-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #16c47f;
  font-size: 30rpx;
  font-weight: 700;
}

.map-card {
  overflow: hidden;
}

.map-frame {
  width: 100%;
  height: 620rpx;
}

.avatar-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.muted-text {
  color: #6b7280;
}
