.home-page__hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 12rpx;
}

.home-page__map {
  position: relative;
  margin-top: 40rpx;
}

.home-page__map-pin {
  position: absolute;
  top: 48%;
  left: 52%;
  width: 36rpx;
  height: 36rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: #16c47f;
  box-shadow: 0 0 0 16rpx rgba(22, 196, 127, 0.18);
}

.home-page__map-pin::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -10rpx;
  width: 16rpx;
  height: 16rpx;
  transform: translateX(-50%) rotate(45deg);
  border-radius: 4rpx;
  background: #16c47f;
}

.home-page__map-control {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #374151;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.12);
}

.home-page__location {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 36rpx;
  padding: 28rpx;
}

.home-page__location-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(22, 196, 127, 0.14);
  color: #0f9f68;
  font-size: 32rpx;
  font-weight: 700;
}

.home-page__location-copy {
  flex: 1;
}

.home-page__location-label {
  font-size: 26rpx;
  color: #6b7280;
}

.home-page__location-name {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #111827;
}

.home-page__location-detail {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.home-page__chevron {
  color: #9ca3af;
  font-size: 40rpx;
  font-weight: 700;
}

.home-page__primary {
  margin-top: 140rpx;
}

.home-page__secondary-row {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.home-page__secondary {
  padding: 0;
  line-height: 1.4;
  background: transparent;
}
